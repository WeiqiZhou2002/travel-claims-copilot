# Server-side only. Do not expose this value through NEXT_PUBLIC_* variables.
OPENAI_API_KEY=

# Classification/extraction defaults to the lower-latency GPT-5.6 family tier.
OPENAI_INTAKE_MODEL=gpt-5.6-luna

# Optional override for compatible gateways. The default is https://api.openai.com/v1.
# OPENAI_BASE_URL=

