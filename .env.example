# Select the provider used by the guided intake flow. Credentials are server-side only:
# never prefix them with NEXT_PUBLIC_ or commit a value.
LLM_PROVIDER=deepseek

# OpenAI-compatible guided intake configuration.
OPENAI_API_KEY=
OPENAI_INTAKE_MODEL=gpt-5.6-luna
OPENAI_BASE_URL=https://api.openai.com/v1

# DeepSeek guided intake configuration.
DEEPSEEK_API_KEY=
DEEPSEEK_INTAKE_MODEL=deepseek-v4-flash
DEEPSEEK_BASE_URL=https://api.deepseek.com

# Server-side judge/demo gate for the canonical OpenAI GPT mode. Enter a strong value directly
# in the host dashboard. This route remains pinned to OpenAI for its reviewed release controls;
# the guided intake flow above supports either provider.
DEMO_ACCESS_CODE=

# Global deployment controls are configured outside process memory: 10 GPT requests/IP/minute,
# 60/IP/hour, and 2 concurrent/IP, plus an OpenAI project spend limit. If those controls cannot be
# proved across instances, keep DEMO_ACCESS_CODE enabled and do not expose GPT mode unrestricted.

# Supplied automatically by Vercel for Git-backed deployments; otherwise use the deployed 40-hex SHA.
VERCEL_GIT_COMMIT_SHA=

# Public non-secret application version shown by /api/health.
APP_VERSION=0.1.0
